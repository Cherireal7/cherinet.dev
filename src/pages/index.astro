---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import HeroMotif from "../components/HeroMotif.astro";
import StepGlyph from "../components/StepGlyph.astro";
import { featuredProjects } from "../lib/projects";
import { site } from "../lib/site";

const loopPhases = [
  { glyph: 2, label: "Discover", note: "Interviews, surveys, competitor maps, heatmaps." },
  { glyph: 3, label: "Strategy", note: "Position. Blue / red ocean. Frame the real constraint." },
  { glyph: 5, label: "Design", note: "Sketch flows, then Figma, then tokens." },
  { glyph: 6, label: "Build", note: "React, Next, React Native, design-in-build." },
  { glyph: 8, label: "Measure", note: "Analytics, SEO, funnel, then reduce." },
];
---

<BaseLayout current="Work">
  <!-- Hero -->
  <section class="relative overflow-hidden px-6 pb-20 pt-40 md:px-10 md:pb-32 md:pt-48">
    <HeroMotif />
    <div class="relative mx-auto max-w-6xl">
      <div class="flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-ink-subtle">
        <span class="inline-block size-1.5 rounded-full bg-accent"></span>
        <span>Available · Remote · {site.location}</span>
      </div>

      <h1
        class="mt-8 font-display font-medium leading-[0.95] tracking-[-0.035em] text-ink"
        style="font-size: var(--text-display-2xl);"
      >
        Product designer<br />
        <span class="italic text-ink-muted">&amp; frontend</span>
        <span class="relative inline-block">
          engineer.
          <span
            class="absolute -bottom-2 left-0 h-[6px] w-full rounded-full bg-accent md:-bottom-3 md:h-[10px]"
            aria-hidden="true"></span>
        </span>
      </h1>

      <p class="mt-10 max-w-2xl text-lg leading-relaxed text-ink-muted md:text-xl">
        I run the full UX loop end-to-end — research, strategy, design, build, measure — from one operator. Co-founder of <a
          href="https://github.com/Cherireal7"
          class="accent-underline text-ink"
          >Doxa Innovations</a
        > and <a href="#work" class="accent-underline text-ink">FIDA Delivery</a>. Based in Bishoftu — open to a senior role with full bandwidth.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a
          href="#work"
          class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-bg transition-colors hover:bg-accent"
        >
          See selected work
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 5v14M5 12l7 7 7-7"></path>
          </svg>
        </a>
        <a
          href={`mailto:${site.email}`}
          class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-line bg-bg-elevated px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-line-strong hover:bg-line/40"
        >
          Email me
        </a>
        <a
          href="/cv"
          class="inline-flex cursor-pointer items-center gap-2 rounded-full px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:text-ink"
        >
          CV →
        </a>
      </div>

      <!-- Quiet stat row -->
      <dl class="mt-20 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-6 border-t border-line pt-8 md:grid-cols-3">
        <div>
          <dt class="text-xs uppercase tracking-widest text-ink-subtle">Co-founder</dt>
          <dd class="mt-1.5 text-sm text-ink">Doxa · FIDA</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-widest text-ink-subtle">Disciplines</dt>
          <dd class="mt-1.5 text-sm text-ink">Research · Design · Engineering · Growth</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-widest text-ink-subtle">Stack</dt>
          <dd class="mt-1.5 text-sm text-ink">Figma · React · Next · React Native</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Approach loop -->
  <section class="border-y border-line bg-bg-elevated px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="reveal mb-12 grid gap-6 md:mb-16 md:grid-cols-12 md:items-end">
        <div class="md:col-span-7">
          <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">01 — Approach</p>
          <h2
            class="mt-4 font-display font-medium tracking-tight text-ink"
            style="font-size: var(--text-display-lg);"
          >
            UX is the whole loop —
            <span class="italic text-ink-muted">not just the screen.</span>
          </h2>
        </div>
        <p class="text-base leading-relaxed text-ink-muted md:col-span-5">
          Most teams call a Figma file "UX." I think UX starts at the customer interview and ends at the funnel report. I run every phase — research and competitor analysis to design system to React Native to SEO and growth — from one operator.
        </p>
      </div>

      <ol class="grid gap-4 md:grid-cols-5 md:gap-5">
        {loopPhases.map((p, i) => (
          <li class="reveal relative flex flex-col rounded-xl border border-line bg-bg p-5 md:p-6" style={`transition-delay: ${i * 80}ms;`}>
            <div class="flex items-center justify-between">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-line">
                <StepGlyph step={p.glyph} size={28} />
              </div>
              <span class="font-mono text-[11px] text-ink-subtle">0{i + 1}</span>
            </div>
            <p class="mt-5 font-display text-xl tracking-tight text-ink">{p.label}.</p>
            <p class="mt-2 text-[13px] leading-relaxed text-ink-muted">{p.note}</p>
            {i < loopPhases.length - 1 && (
              <span class="absolute right-[-12px] top-1/2 hidden h-px w-6 -translate-y-1/2 bg-line-strong md:block" aria-hidden="true"></span>
            )}
          </li>
        ))}
      </ol>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/how-i-work" class="inline-flex items-center gap-1.5 text-sm font-medium text-ink accent-underline">
          Read the full process →
        </a>
        <a href="/system" class="text-sm text-ink-muted accent-underline hover:text-ink">
          Or the design system →
        </a>
      </div>
    </div>
  </section>

  <!-- Selected work -->
  <section id="work" class="scroll-mt-28 px-6 pb-20 pt-20 md:px-10 md:pb-32 md:pt-28">
    <div class="mx-auto max-w-6xl">
      <div class="reveal mb-10 flex items-end justify-between gap-6 md:mb-14">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">
            02 — Selected work
          </p>
          <h2
            class="mt-4 font-display font-medium tracking-tight text-ink"
            style="font-size: var(--text-display-lg);"
          >
            Things I&rsquo;ve shipped.
          </h2>
        </div>
        <a
          href="/work"
          class="hidden shrink-0 text-sm font-medium text-ink-muted accent-underline hover:text-ink md:inline-block"
        >
          View all →
        </a>
      </div>

      <div class="grid auto-rows-fr gap-5 md:grid-cols-2 md:gap-6">
        {featuredProjects.map((p, i) => <ProjectCard project={p} index={i} />)}
      </div>
    </div>
  </section>

  <!-- About preview -->
  <section class="border-t border-line bg-bg-elevated px-6 py-24 md:px-10 md:py-32">
    <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">03 — About</p>
      </div>
      <div class="reveal md:col-span-8">
        <p
          class="font-display font-medium leading-tight tracking-tight text-ink"
          style="font-size: var(--text-display-lg);"
        >
          I lead design systems —
          <span class="text-ink-subtle">then I build them.</span>
        </p>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-muted">
          My path runs operations → UI/UX → product engineering. I started in systems
          implementation — rolling out a school management platform across two campuses —
          and grew into frontend leadership through a UI/UX internship and a
          digital-content role with a measurable revenue lift.
        </p>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">
          Today I lead frontend architecture at Doxa Innovations, ship FIDA on the side,
          and work directly with business owners and NGO leadership to turn vague
          requirements into shipped product.
        </p>
        <a
          href="/about"
          class="mt-10 inline-flex items-center gap-1.5 text-sm font-medium text-ink accent-underline"
        >
          More about me →
        </a>
      </div>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="px-6 py-24 md:px-10 md:py-32">
    <div class="mx-auto max-w-6xl">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">04 — Get in touch</p>
      <h2
        class="reveal mt-4 max-w-3xl font-display font-medium leading-[0.95] tracking-[-0.025em] text-ink"
        style="font-size: var(--text-display-xl);"
      >
        Have a role, a project, or a question?
        <a
          href={`mailto:${site.email}`}
          class="text-accent accent-underline"
          style="background-size: 100% 4px;"
        >
          Say hi.
        </a>
      </h2>

      <div class="mt-12 grid gap-6 border-t border-line pt-8 md:grid-cols-3">
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">Email</p>
          <a
            href={`mailto:${site.email}`}
            class="mt-2 block text-base text-ink hover:text-accent"
            >{site.email}</a
          >
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">GitHub</p>
          <a
            href={site.social.github.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 block text-base text-ink hover:text-accent">@Cherireal7 ↗</a
          >
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">LinkedIn</p>
          <a
            href={site.social.linkedin.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 block text-base text-ink hover:text-accent">cherinet-Demeke ↗</a
          >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
