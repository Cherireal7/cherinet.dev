---
import BaseLayout from "../layouts/BaseLayout.astro";
import { img } from "../lib/images";

interface Tool {
  name: string;
  blurb: string;
  repo?: string;
  live?: string;
  tag: string;
  status?: "live" | "wip" | "archive";
}

const tools: Tool[] = [
  {
    name: "Ge'ez Transcribe",
    blurb:
      "Browser-based transcription tool for Ge'ez script — Ethiopia's ancient liturgical language. Pure client-side, works offline.",
    live: "https://geez-transcribe.vercel.app",
    repo: "https://github.com/Cherireal7/geez-transcribe",
    tag: "Language / OSS",
    status: "live",
  },
  {
    name: "Liturgical Data Engine",
    blurb:
      "Open data layer for Christian liturgical calendars, lectionaries, and feast days. JSON API + cron-ready.",
    live: "https://liturgical-data-engine.vercel.app",
    repo: "https://github.com/Cherireal7/liturgical-data-engine",
    tag: "Data / OSS",
    status: "live",
  },
  {
    name: "Dr. Brug Archive",
    blurb:
      "Searchable online archive of Dr. John F. Brug's writings. Long-form scholarship rendered through MDX + Astro.",
    repo: "https://github.com/Cherireal7/drbrug",
    tag: "Archive / OSS",
    status: "wip",
  },
  {
    name: "Apartment Guide PWA",
    blurb:
      "Offline-first PWA for browsing Bishoftu rentals. Installable, fast, service-worker cached imagery.",
    live: "https://apartment-guide-pwa.vercel.app",
    repo: "https://github.com/Cherireal7/apartment-guide-pwa",
    tag: "PWA",
    status: "live",
  },
  {
    name: "Project Nexus — Movie Rec",
    blurb:
      "Clean Next.js UX over TMDB. Watchlists, taste graph, server-rendered search.",
    live: "https://project-nexus-movie-recommendation.vercel.app",
    repo: "https://github.com/Cherireal7/project-nexus",
    tag: "Product demo",
    status: "live",
  },
  {
    name: "Christian Worship App",
    blurb:
      "Mobile-first worship companion — songbooks, daily readings, prayer flow.",
    repo: "https://github.com/Cherireal7/christian-worship-app",
    tag: "Mobile / OSS",
    status: "wip",
  },
  {
    name: "AI Automation — n8n Workflows",
    blurb:
      "Reusable n8n workflows for content ops, lead routing, analytics push.",
    repo: "https://github.com/Cherireal7/AI-Automation-Workflows-n8n",
    tag: "Automation",
    status: "live",
  },
  {
    name: "Plug-and-play Blog",
    blurb:
      "Starter blog template — Next.js + MDX + Tailwind. Tagged drafts, RSS, opinionated typography.",
    repo: "https://github.com/Cherireal7/plug-and-play-blog",
    tag: "Template",
    status: "live",
  },
];

const statusStyle = {
  live: "border-accent/40 bg-accent/5 text-accent",
  wip: "border-line-strong bg-bg text-ink",
  archive: "border-line bg-bg-elevated text-ink-subtle",
} as const;
---

<BaseLayout
  title="Tools I built"
  description="Small open-source projects, demos, and tooling by Cherinet Demeke."
  current="Tools"
>
  <!-- Hero -->
  <section class="px-6 pb-12 pt-36 md:px-10 md:pb-20 md:pt-44">
    <div class="mx-auto max-w-6xl">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">Open source · Demos · Snippets</p>
      <h1
        class="mt-6 max-w-4xl font-display font-medium leading-[1.02] tracking-[-0.03em] text-ink"
        style="font-size: var(--text-display-xl);"
      >
        Tools
        <span class="italic text-ink-muted">I built.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-muted">
        Side projects, one-shot demos, and the small infrastructure I keep around to make new projects faster. Some are scratch-an-itch, some are real OSS, all are public on <a href="https://github.com/Cherireal7" target="_blank" rel="noopener" class="accent-underline text-ink">GitHub</a>.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="px-6 pb-20 md:px-10 md:pb-28">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-5 md:grid-cols-2 md:gap-6">
        {tools.map((t, i) => (
          <article class="reveal flex flex-col rounded-xl border border-line bg-bg-elevated p-6 md:p-7" style={`transition-delay: ${i * 50}ms;`}>
            <div class="flex items-center justify-between gap-3">
              <span class="text-[10px] uppercase tracking-widest text-ink-subtle">{t.tag}</span>
              {t.status && (
                <span class:list={["inline-flex items-center gap-1.5 rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-widest", statusStyle[t.status]]}>
                  <span class="size-1.5 rounded-full bg-current"></span>
                  {t.status === "wip" ? "Work in progress" : t.status}
                </span>
              )}
            </div>
            <h3 class="mt-5 font-display text-2xl tracking-tight text-ink md:text-3xl">{t.name}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-muted md:text-[15px]">{t.blurb}</p>
            <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
              {t.live && (
                <a href={t.live} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-ink px-3.5 py-1.5 font-medium text-bg transition-colors hover:bg-accent">
                  Live
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg>
                </a>
              )}
              {t.repo && (
                <a href={t.repo} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-line bg-bg px-3.5 py-1.5 font-medium text-ink transition-colors hover:border-line-strong">
                  Source
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub strip -->
  <section class="border-t border-line bg-bg-elevated px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-12 md:items-center">
      <div class="md:col-span-7">
        <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">More on GitHub</p>
        <h2
          class="mt-4 font-display font-medium tracking-tight text-ink"
          style="font-size: var(--text-display-lg);"
        >
          ALX coursework, experiments, and configs.
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-muted">
          The rest is on GitHub — ALX program submissions, code snippets, and the configs I carry between machines.
        </p>
        <a
          href="https://github.com/Cherireal7"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-bg transition-colors hover:bg-accent"
        >
          @Cherireal7
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg>
        </a>
      </div>
      <div class="md:col-span-5">
        <img
          src={img("code-editor", { w: 1400 })}
          alt="Code on screen"
          class="aspect-[4/3] w-full rounded-xl border border-line object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>
</BaseLayout>
