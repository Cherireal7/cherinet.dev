---
import BaseLayout from "../layouts/BaseLayout.astro";
import { img, imgCredit } from "../lib/images";

interface Book {
  title: string;
  by: string;
  note: string;
  year?: string;
  status?: "reading" | "reread" | "finished";
}

interface Shelf {
  slug: "theology" | "philosophy" | "science" | "history" | "craft";
  title: string;
  blurb: string;
  image: "books-old" | "philosophy" | "science-lab" | "history-archive" | "manuscript";
  books: Book[];
}

const shelves: Shelf[] = [
  {
    slug: "theology",
    title: "Theology",
    blurb:
      "The questions that don&rsquo;t go away when the office closes. Mostly Reformation-tradition, with a soft spot for the Eastern fathers.",
    image: "manuscript",
    books: [
      { title: "Confessions", by: "Augustine", note: "The most personal philosophy ever written. Re-read this year.", status: "reread" },
      { title: "On the Incarnation", by: "Athanasius", note: "Short. Decisive. The kind of clarity I aim for in product writing." },
      { title: "The Cost of Discipleship", by: "Dietrich Bonhoeffer", note: "Cheap grace and the work of following." },
      { title: "Christ the Lord", by: "John F. Brug", note: "Connected reason I&rsquo;m building the Dr. Brug Archive." },
      { title: "Knowing God", by: "J. I. Packer", note: "Pastoral theology with engineering precision." },
    ],
  },
  {
    slug: "philosophy",
    title: "Philosophy",
    blurb:
      "Why we believe what we believe, and whether the ground holds.",
    image: "philosophy",
    books: [
      { title: "After Virtue", by: "Alasdair MacIntyre", note: "Why modern moral language is a wreck. Currently reading.", status: "reading" },
      { title: "The Abolition of Man", by: "C. S. Lewis", note: "Three short lectures with consequences." },
      { title: "Personal Knowledge", by: "Michael Polanyi", note: "Tacit knowing. Relevant for design and code." },
      { title: "Orthodoxy", by: "G. K. Chesterton", note: "Wit as argument." },
      { title: "Pensées", by: "Blaise Pascal", note: "Fragments that hold up after centuries." },
    ],
  },
  {
    slug: "science",
    title: "Science & history of science",
    blurb:
      "Where the frontier sits, and how it got there.",
    image: "science-lab",
    books: [
      { title: "The Genesis of Science", by: "James Hannam", note: "Counter-narrative on medieval science. Currently reading.", status: "reading" },
      { title: "The Structure of Scientific Revolutions", by: "Thomas Kuhn", note: "Paradigms, anomaly, normal science." },
      { title: "Seven Brief Lessons on Physics", by: "Carlo Rovelli", note: "Compressed clarity." },
      { title: "Gödel, Escher, Bach", by: "Douglas Hofstadter", note: "Long-running re-read." },
    ],
  },
  {
    slug: "history",
    title: "History",
    blurb:
      "Mostly Ethiopian, late-antique, and Reformation. The stories that explain the present.",
    image: "history-archive",
    books: [
      { title: "Layers of Time: A History of Ethiopia", by: "Paul B. Henze", note: "Standard one-volume history." },
      { title: "The Sign and the Seal", by: "Graham Hancock", note: "Read critically. Useful for the Ark / Axum story." },
      { title: "The Reformation", by: "Diarmaid MacCulloch", note: "Sprawling, fair, indispensable." },
      { title: "Civilization: The West and the Rest", by: "Niall Ferguson", note: "Provocative thesis on six 'killer apps'." },
    ],
  },
  {
    slug: "craft",
    title: "Craft",
    blurb:
      "Design, engineering, and the work of making things.",
    image: "books-old",
    books: [
      { title: "Refactoring UI", by: "Wathan & Schoger", note: "Most actionable design book I&rsquo;ve read." },
      { title: "A Philosophy of Software Design", by: "John Ousterhout", note: "Deep modules, shallow APIs. Reread yearly." },
      { title: "The Pragmatic Programmer", by: "Hunt & Thomas", note: "Aging well." },
      { title: "Designing Data-Intensive Applications", by: "Martin Kleppmann", note: "The backend bible. Useful even for FE leads." },
    ],
  },
];

const credit = imgCredit("books-old");

const statusBadge = (s?: Book["status"]) => {
  if (s === "reading") return { label: "Reading now", cls: "border-accent/40 bg-accent/5 text-accent" };
  if (s === "reread") return { label: "Re-reading", cls: "border-line-strong bg-bg text-ink" };
  return null;
};
---

<BaseLayout
  title="Reading"
  description="An annotated library — theology, philosophy, science, history, craft."
  current="Reading"
>
  <!-- Hero -->
  <section class="px-6 pb-12 pt-36 md:px-10 md:pb-20 md:pt-44">
    <div class="mx-auto max-w-6xl">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">Library</p>
      <h1
        class="mt-6 max-w-4xl font-display font-medium leading-[1.02] tracking-[-0.03em] text-ink"
        style="font-size: var(--text-display-xl);"
      >
        Books that
        <span class="italic text-ink-muted">shape the work.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-muted">
        A working library, not a brag list. These are books I&rsquo;ve actually read — or am working through — and that show up in how I think, build, and write.
      </p>

      <!-- Anchor nav -->
      <nav class="mt-10 flex flex-wrap items-center gap-2 text-sm">
        {shelves.map((s) => (
          <a href={`#${s.slug}`} class="rounded-full border border-line bg-bg-elevated px-3.5 py-1.5 text-ink-muted transition-colors hover:border-line-strong hover:text-ink">
            {s.title}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Hero image -->
  <section class="px-6 pb-20 md:px-10 md:pb-28">
    <div class="mx-auto max-w-6xl">
      <div class="relative overflow-hidden rounded-xl border border-line">
        <img
          src={img("books-old", { w: 2400 })}
          alt="Old open book"
          class="aspect-[16/7] w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute bottom-3 right-3 rounded-full bg-white/80 px-2.5 py-1 text-[10px] uppercase tracking-widest text-ink backdrop-blur">
          <a href={credit.href} target="_blank" rel="noopener" class="hover:text-accent">{credit.credit} ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Shelves -->
  {shelves.map((shelf, idx) => (
    <section id={shelf.slug} class:list={["scroll-mt-28 px-6 py-20 md:px-10 md:py-28", idx % 2 === 1 && "border-y border-line bg-bg-elevated"]}>
      <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4">
          <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">
            Shelf · {String(idx + 1).padStart(2, "0")}
          </p>
          <h2
            class="mt-4 font-display font-medium tracking-tight text-ink"
            style="font-size: var(--text-display-lg);"
          >
            {shelf.title}.
          </h2>
          <p class="mt-6 max-w-md text-base leading-relaxed text-ink-muted" set:html={shelf.blurb} />
          <div class="mt-8 overflow-hidden rounded-xl border border-line">
            <img
              src={img(shelf.image, { w: 1200 })}
              alt=""
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <ul class="md:col-span-8 md:divide-y md:divide-line">
          {shelf.books.map((b, i) => {
            const badge = statusBadge(b.status);
            return (
              <li class:list={["reveal grid gap-2 py-6 md:grid-cols-12 md:gap-6", i === 0 && "md:pt-0"]}>
                <div class="md:col-span-5">
                  <p class="font-display text-xl tracking-tight text-ink">{b.title}</p>
                  <p class="mt-1 text-sm text-ink-muted">by {b.by}</p>
                  {badge && (
                    <span class:list={["mt-2 inline-flex items-center gap-1.5 rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-widest", badge.cls]}>
                      <span class="size-1.5 rounded-full bg-current"></span>
                      {badge.label}
                    </span>
                  )}
                </div>
                <p class="text-sm leading-relaxed text-ink-muted md:col-span-7" set:html={b.note} />
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  ))}

  <!-- Closing -->
  <section class="px-6 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">Recommend something</p>
      <h2
        class="mt-4 font-display font-medium tracking-tight text-ink"
        style="font-size: var(--text-display-lg);"
      >
        What should I read next?
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-ink-muted">
        I&rsquo;m always taking suggestions, especially across these shelves. If a book changed how you think, send it my way.
      </p>
      <a href="/contact" class="mt-8 inline-flex cursor-pointer items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-bg transition-colors hover:bg-accent">
        Send a recommendation
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </section>
</BaseLayout>
