---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site";

const experience = [
  {
    year: "Nov 2024 — present",
    title: "Co-founder & Vice Manager · Product Designer + Front-End",
    org: "Doxa Innovations Software Development PLC · Bishoftu, Ethiopia",
    bullets: [
      "Co-founded Doxa with two technical partners; own UI/UX, product design, brand strategy, and front-end across all engagements.",
      "Eight client projects shipped across Ethiopia and the US: Yeneta Master SIS, Maor Lutheran Theological Seminary, KLA Construction Equipment, MySeed, Classic Noodle, Zoe Plant Delivery, Scholten Pattern Works, ZOA Ethiopia.",
      "Standard stack across the studio: Tailwind + React/Next.js + Laravel + PostgreSQL/MySQL + Redis + Cloudflare R2.",
      "Scope spans landing surfaces, full multi-tenant SaaS, US e-commerce with eBay SOAP integration, and bilingual (Amharic/English) admin tooling.",
    ],
  },
  {
    year: "2025 — present",
    title: "Co-founder · design + engineering",
    org: "FIDA Delivery",
    bullets: [
      "Co-founded FIDA; designed and shipped two production React Native apps (customer + rider) on Expo SDK 56 / New Architecture / React 19.2 / RN 0.85.",
      "Stack: MapLibre, TanStack Query (with persist + sync storage), Firebase Messaging + Notifee, MMKV, Reanimated 4, i18next, React Hook Form.",
      "Built shared `@fida/ui` package — tokens, primitives, and screens — consumed by both apps and the marketing site.",
      "Set up EAS Build + Updates pipeline; wired OTA channels for staged rollout.",
      "Built the marketing site and Telegram Mini App in Next.js 16.2 + React 19 + Tailwind v4, with a MapLibre GL coverage view and openapi-typescript API client.",
    ],
  },
  {
    year: "2025 — present",
    title: "Frontend lead",
    org: "BizBridge Ethiopia",
    bullets: [
      "Frontend lead in a Turborepo with Next.js 15, Payload v3 CMS, Fastify, Drizzle, Better Auth, Neon Postgres, Chapa + Stripe payments, Cal.com booking, MeiliSearch lookup, BullMQ workers.",
      "Built sector search, expert booking, and payment flows — bilingual (Amharic/English) with Ministry of Revenue source documents driving the seeder.",
    ],
  },
  {
    year: "mid 2024 — 2025",
    title: "UI/UX Designer · Front-end Developer",
    org: "Selected Bishoftu engagements",
    bullets: [
      "Restaurant brands, faith-led organizations, and small-business surfaces.",
      "Transition period from design work into front-end engineering. Formalized when Doxa was co-founded in late 2024.",
    ],
  },
  {
    year: "2021 — 2024",
    title: "Operations & systems implementation",
    org: "Bishoftu education sector",
    bullets: [
      "Pre-engineering career: school operations and systems implementation.",
      "Practical grounding for how I design admin tooling today — including Yeneta Master SIS at Doxa.",
    ],
  },
];

const education = [
  {
    year: "expected 2026",
    title: "BA in Theology",
    org: "Maor Lutheran Theological Seminary, Bishoftu",
    note: "Confessional Lutheran formation. Doxa built the seminary's website (a coincidence of vocation and work).",
  },
  {
    year: "expected 2029",
    title: "BA in Business Management",
    org: "Unity University, Addis Ababa",
    note: "Part-time alongside Doxa and FIDA.",
  },
  {
    year: "2023",
    title: "CCNA — Networking",
    org: "Ethiopian University of Defense",
    note: "Cisco Certified Network Associate.",
  },
  {
    year: "2022 — 2024",
    title: "ALX Africa — multiple programs",
    org: "ALX Africa",
    note: "Software Engineering · Foundations · Content Creation · Graphic Design.",
  },
];

const skills = {
  "Research & discovery": [
    "User interviews & ethnography",
    "Surveys (paper + digital)",
    "Heatmaps & session replay",
    "Competitor & market analysis",
    "Population & demographic study",
    "UX psychology (defaults, loss aversion, friction design)",
  ],
  "Strategy & business": [
    "Blue / red ocean positioning",
    "Pricing & willingness-to-pay",
    "Go-to-market scoping",
    "Partner & vendor onboarding",
    "Business development (NGO + private)",
    "Product roadmap framing",
  ],
  "Design & systems": [
    "Figma (variables-first, tokens, variants)",
    "Spline (3D / hero moments)",
    "Design systems & tokens",
    "Motion (Framer Motion / Reanimated)",
    "Accessibility (WCAG)",
    "Bilingual product (Amharic / English)",
  ],
  "Languages & frameworks": [
    "TypeScript",
    "React",
    "React Native",
    "Next.js (15/16)",
    "Astro",
    "Node.js",
  ],
  "Mobile & release": [
    "Expo SDK 56",
    "React Native New Arch",
    "EAS Build & Updates",
    "Continuous native generation",
    "OTA channels",
  ],
  "Backend & data": [
    "Laravel (primary backend across Doxa client work)",
    "Payload v3 CMS",
    "Fastify",
    "Drizzle ORM",
    "PostgreSQL / Neon",
    "MySQL",
    "Redis / BullMQ",
    "Better Auth · NextAuth",
    "REST + GraphQL API design",
  ],
  "Growth & measurement": [
    "Technical SEO (schema, sitemaps, Core Web Vitals)",
    "Content SEO & site architecture",
    "Analytics (GA4, Plausible)",
    "Funnel & cohort analysis",
    "CRO & A/B testing",
    "Heatmap-driven iteration",
  ],
};
---

<BaseLayout
  title="CV"
  description={`CV of ${site.name} — ${site.role}, ${site.location}.`}
  current="CV"
>
  <section class="cv-root px-6 pb-24 pt-36 md:px-10 md:pb-32 md:pt-44">
    <div class="mx-auto max-w-4xl">
      <!-- Header -->
      <header class="flex flex-col gap-6 border-b border-line pb-10 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-ink-subtle">Curriculum vitae</p>
          <h1
            class="mt-3 font-display font-medium leading-[1.02] tracking-[-0.025em] text-ink"
            style="font-size: var(--text-display-xl);"
          >
            {site.name}
          </h1>
          <p class="mt-3 text-lg text-ink-muted">{site.role} · {site.location}</p>
        </div>

        <div class="no-print flex flex-wrap items-center gap-3">
          <button
            type="button"
            data-print
            class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-bg transition-colors hover:bg-accent"
          >
            Save as PDF
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
            </svg>
          </button>
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 rounded-full border border-line bg-bg-elevated px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-line-strong"
          >
            Email
          </a>
        </div>
      </header>

      <!-- Contact strip -->
      <div class="cv-contact mt-8 grid grid-cols-2 gap-x-6 gap-y-4 md:grid-cols-4">
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">Email</p>
          <a href={`mailto:${site.email}`} class="mt-1 block text-sm text-ink">{site.email}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">Phone</p>
          <p class="mt-1 text-sm text-ink">{site.phone}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">GitHub</p>
          <a href={site.social.github.href} target="_blank" rel="noopener noreferrer" class="mt-1 block text-sm text-ink">
            Cherireal7
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-subtle">LinkedIn</p>
          <a href={site.social.linkedin.href} target="_blank" rel="noopener noreferrer" class="mt-1 block text-sm text-ink">
            cherinet-Demeke
          </a>
        </div>
      </div>

      <!-- Profile -->
      <section class="mt-12">
        <h2 class="cv-h2 text-xs uppercase tracking-[0.18em] text-ink-subtle">Profile</h2>
        <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-muted">
          Product designer and frontend engineer based in Bishoftu, Ethiopia. Co-founder & Vice Manager at Doxa Innovations Software Development PLC (UI/UX, product design, brand strategy, front-end) and co-founder of FIDA Delivery (design + engineering across two production apps). UX practice covers the full loop — interviews, surveys, competitor + market analysis, blue / red ocean positioning, design systems, Figma → React / React Native, SEO and analytics. Open to senior frontend / staff roles, remote — with full bandwidth.
        </p>
      </section>

      <!-- Experience -->
      <section class="mt-12">
        <h2 class="cv-h2 text-xs uppercase tracking-[0.18em] text-ink-subtle">Experience</h2>
        <ol class="mt-4 space-y-8">
          {
            experience.map((role) => (
              <li class="grid gap-3 md:grid-cols-12 md:gap-6">
                <div class="md:col-span-3">
                  <p class="text-xs uppercase tracking-widest text-ink-subtle">{role.year}</p>
                </div>
                <div class="md:col-span-9">
                  <h3 class="font-display text-lg font-medium leading-tight tracking-tight text-ink md:text-xl">
                    {role.title}
                  </h3>
                  <p class="mt-1 text-sm text-ink-muted">{role.org}</p>
                  <ul class="mt-3 list-disc space-y-1.5 pl-5 text-[15px] leading-relaxed text-ink-muted marker:text-ink-subtle">
                    {role.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- Education -->
      <section class="mt-12">
        <h2 class="cv-h2 text-xs uppercase tracking-[0.18em] text-ink-subtle">Education & Certifications</h2>
        <ol class="mt-4 space-y-6">
          {
            education.map((e) => (
              <li class="grid gap-3 md:grid-cols-12 md:gap-6">
                <div class="md:col-span-3">
                  <p class="text-xs uppercase tracking-widest text-ink-subtle">{e.year}</p>
                </div>
                <div class="md:col-span-9">
                  <h3 class="font-display text-base font-medium leading-tight tracking-tight text-ink md:text-lg">
                    {e.title}
                  </h3>
                  <p class="mt-1 text-sm text-ink-muted">{e.org}</p>
                  <p class="mt-2 text-[15px] leading-relaxed text-ink-muted">{e.note}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- Skills -->
      <section class="mt-12">
        <h2 class="cv-h2 text-xs uppercase tracking-[0.18em] text-ink-subtle">Skills</h2>
        <dl class="mt-4 grid gap-6 md:grid-cols-2">
          {
            Object.entries(skills).map(([group, items]) => (
              <div>
                <dt class="font-display text-base font-medium tracking-tight text-ink">{group}</dt>
                <dd class="mt-1.5 text-[15px] leading-relaxed text-ink-muted">
                  {items.join(" · ")}
                </dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- Languages -->
      <section class="mt-12">
        <h2 class="cv-h2 text-xs uppercase tracking-[0.18em] text-ink-subtle">Languages</h2>
        <p class="mt-4 text-[15px] text-ink-muted">
          <span class="text-ink">English</span> — full professional · <span class="text-ink">Amharic</span> — native
        </p>
      </section>

      <!-- References -->
      <section class="mt-12 border-t border-line pt-8">
        <p class="text-sm text-ink-muted">
          References and detailed project case studies available on request — email
          <a href={`mailto:${site.email}`} class="text-ink accent-underline">{site.email}</a>.
        </p>
      </section>
    </div>
  </section>

  <script is:inline>
    document.querySelector("[data-print]")?.addEventListener("click", () => window.print());
  </script>

  <style is:global>
    @media print {
      header[data-nav],
      footer,
      .no-print {
        display: none !important;
      }
      .cv-root {
        padding: 0 !important;
      }
      body {
        background: #fff !important;
      }
      .reveal {
        opacity: 1 !important;
        transform: none !important;
      }
      a {
        color: inherit !important;
        text-decoration: none !important;
      }
      .cv-contact { font-size: 11px; }
    }
  </style>
</BaseLayout>
